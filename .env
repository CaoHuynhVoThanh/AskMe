APP_ENV=development

# LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=askme-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_EVAL_DATASET=askme-rag-eval

# Hugging Face
HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_REASONING_MODEL=google/flan-t5-base
HF_DEVICE=cpu

# Qdrant local
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=askme_documents

# Retrieval
RETRIEVER_TOP_K=5
CHUNK_SIZE=900
CHUNK_OVERLAP=150
