APP_ENV=development

# LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=askme-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_EVAL_DATASET=askme-rag-eval

# Hugging Face
HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
HF_DEVICE=cpu

# Local GGUF text generation
LLM_BACKEND=llama_cpp
LLM_MODEL_PATH=E:\LLMs\Vi-Qwen2-7B-RAG.Q2_K.gguf

# High-context profile, commented out because it needs much more RAM/KV cache.
# LLM_N_CTX=32768
# LLM_CONTEXT_FALLBACKS=32768,24576,16384,8192,4096
# LLM_MAX_INPUT_TOKENS=28672
# LLM_CONTEXT_TOKEN_BUDGET=24000

# Low-memory profile for getting the app running.
LLM_N_CTX=4096
LLM_CONTEXT_FALLBACKS=4096
LLM_MAX_INPUT_TOKENS=3072
LLM_CONTEXT_TOKEN_BUDGET=2200
LLM_MAX_OUTPUT_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_N_GPU_LAYERS=0
LLM_N_THREADS=0
LLM_N_BATCH=128
DEBUG_LLM_CONFIG=true
DEBUG_INPUT_CLASSIFICATION=true

RERANKER_MAX_LENGTH=512
ENABLE_RERANKER=true
DEBUG_RERANKER=true

# Qdrant local
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=askme_documents

# Retrieval
RETRIEVER_TOP_K=20
CHUNK_SIZE=600
CHUNK_OVERLAP=100
RERANKER_TOP_K=5
